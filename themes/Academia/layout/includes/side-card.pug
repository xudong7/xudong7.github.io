.side-card.sticky
    .card-wrap(itemscope itemtype='http://schema.org/Person')
        .author-avatar
            img.avatar-img(src=url_for(theme.avatar) onerror=`this.onerror=null;this.src='` + url_for(theme.loading_bg.flink) + `'` alt="avatar")
        .contact-panel
            h3 Contact
            p
                strong Email:
                br
                a(href="mailto:xudong7@mail2.sysu.edu.cn") xudong7@mail2.sysu.edu.cn
            p
                strong Affiliation:
                br
                | School of Software Engineering,
                br
                | Sun Yat-sen University
            if(theme.social.enable)
                ul.social-icons
                    each url, icon in theme.social_links
                        li
                            a.social-icon(href=url target="_blank" rel="noopener")
                                i(class=icon aria-hidden="true")
            if(theme.e_social.enable)
                ul.social-links
                    each value, name in theme.e_social_links
                        li
                            a.e-social-link(href=url_for(trim(value.split('||')[0])) target="_blank" rel="noopener")
                                i(class=trim(value.split('||')[1]) aria-hidden="true")
                                span= name
